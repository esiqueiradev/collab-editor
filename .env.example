# Database
DATABASE_URL="postgresql://collab:collab@localhost:5432/collab_editor"

# Redis
REDIS_URL="redis://localhost:6379"

# NextAuth
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# OAuth providers (register at console.developers.google.com and github.com/settings/apps)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# WebSocket server
NEXT_PUBLIC_WS_URL="ws://localhost:4000"

# Shared between ws-server and web for JWT signing
JWT_SECRET="generate-with-openssl-rand-base64-32"

# ws-server port (optional, defaults to 4000)
PORT=4000
