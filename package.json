{
  "name": "collab-editor",
  "private": true,
  "version": "0.0.1",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "web": "pnpm --filter web",
    "ws": "pnpm --filter ws-server",
